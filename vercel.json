{
  "buildCommand": "npm run build",
  "installCommand": "npm install && cd backend && pip install -r requirements.txt",
  "outputDirectory": ".next",
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONPATH": "."
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/_/backend/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
