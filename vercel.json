{
  "buildCommand": "npm run build",
  "installCommand": "npm install && python -m pip install -r backend/requirements.txt",
  "outputDirectory": ".next",
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONPATH": "/var/task"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "includeFiles": ["backend/**", "*.py"]
    }
  }
}
